generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WishlistStatus {
  draft
  published
  archived
}

enum EventType {
  baby_shower
  birthday
  wedding
  housewarming
  general
}

enum Locale {
  es
  en
}

enum Currency {
  PEN
  USD
  EUR
  MXN
  COP
  CLP
  ARS
}

enum GiftPriority {
  low
  medium
  high
}

enum GiftVisibilityStatus {
  available
  hidden
}

enum RsvpStatus {
  pending
  confirmed
  declined
}

model User {
  id        Int        @id @default(autoincrement())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  imageUrl  String?
  wishlists Wishlist[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Wishlist {
  id              String         @id @default(cuid())
  ownerId         Int
  owner           User           @relation(fields: [ownerId], references: [id])
  categories      Category[]
  gifts           Gift[]
  invites         Invite[]
  title           String
  slug            String         @unique
  eventType       EventType
  language        Locale         @default(es)
  currency        Currency       @default(PEN)
  heroTitle       String?
  welcomeMessage  String?
  thankYouMessage String?
  displayName     String?
  eventDate       DateTime?
  eventTime       String?
  eventLocation   String?
  dressCode       String?
  coverImageUrl   String?
  coverImageUrls  String[]       @default([])
  themeId         String?
  layoutId        String?
  buttonStyle     String?
  fontPairing     String?
  headingFont     String?
  bodyFont        String?
  showHowItWorks  Boolean        @default(true)
  status          WishlistStatus @default(draft)
  publishedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([ownerId])
  @@index([ownerId, status])
}

model Category {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  gifts      Gift[]
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([wishlistId])
  @@index([wishlistId, sortOrder])
}

model Gift {
  id               String               @id @default(cuid())
  wishlistId       String
  wishlist         Wishlist             @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  purchases        Purchase[]
  name             String
  productUrl       String?
  imageUrl         String?
  storeName        String?
  size             String?
  priceAmount      Decimal?             @db.Decimal(10, 2)
  priceCurrency    Currency?
  quantityNeeded   Int                  @default(1)
  priority         GiftPriority         @default(medium)
  visibilityStatus GiftVisibilityStatus @default(available)
  publicNote       String?
  internalNote     String?
  sortOrder        Int                  @default(0)
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([wishlistId])
  @@index([wishlistId, sortOrder])
  @@index([categoryId])
}

model Invite {
  id            String             @id @default(cuid())
  wishlistId    String
  wishlist      Wishlist           @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  extraGuests   InviteExtraGuest[]
  primaryName   String
  primaryEmail  String?
  primaryPhone  String?
  slug          String
  status        RsvpStatus         @default(pending)
  openedAt      DateTime?
  respondedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([wishlistId, slug])
  @@index([wishlistId])
}

model InviteExtraGuest {
  id        String   @id @default(cuid())
  inviteId  String
  invite    Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  name      String?
  sortOrder Int      @default(0)

  @@index([inviteId])
}

model Purchase {
  id            String    @id @default(cuid())
  giftId        String
  gift          Gift      @relation(fields: [giftId], references: [id], onDelete: Cascade)
  guestName     String
  guestEmail    String?
  guestPhone    String?
  message       String?
  quantity      Int       @default(1)
  undoTokenHash String?
  undoExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([giftId])
}
