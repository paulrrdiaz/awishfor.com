generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WishlistStatus {
  draft
  published
  archived
}

enum EventType {
  baby_shower
  birthday
  wedding
  housewarming
  general
}

enum Locale {
  es
  en
}

enum Currency {
  PEN
  USD
  EUR
  MXN
  COP
  CLP
  ARS
}

enum GiftPriority {
  low
  medium
  high
}

enum GiftVisibilityStatus {
  available
  hidden
}

model User {
  id        Int      @id @default(autoincrement())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id          String         @id @default(cuid())
  status      WishlistStatus @default(draft)
  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
