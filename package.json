{
	"name": "awishfor.com",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"dev": "dotenv -e .env -- next dev",
		"preview": "next build && next start",
		"bootstrap": "zx scripts/setup.mjs",
		"start": "next start",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"tunnel": "dotenv -e .env -- sh -c 'ngrok http \"$PORT\" --url=\"$NGROK_URL\"'",
		"postinstall": "prisma generate"
	},
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@clerk/nextjs": "^7.5.8",
		"@hookform/resolvers": "^5.4.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@t3-oss/env-nextjs": "^0.13.0",
		"@tanstack/react-query": "^5.69.0",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@trpc/server": "^11.0.0",
		"@uploadthing/react": "^7.3.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"lucide-react": "^1.21.0",
		"next": "16.2.9",
		"pg": "^8.22.0",
		"qrcode": "^1.5.4",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "^7.80.0",
		"server-only": "^0.0.1",
		"shadcn": "^4.11.0",
		"sonner": "^2.0.7",
		"superjson": "^2.2.1",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"uploadthing": "^7.7.4",
		"use-debounce": "^10.1.1",
		"zod": "^4.0.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@tailwindcss/postcss": "^4.0.15",
