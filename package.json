		"jsdom": "^29.1.1",
		"lefthook": "^2.1.9",
		"postcss": "^8.5.3",
		"prisma": "^7.8.0",
		"tailwindcss": "^4.0.15",
		"tsx": "^4.22.4",
		"typescript": "^6.0.0",
